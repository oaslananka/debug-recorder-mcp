{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/mcp.ts",
    "src/server-http.ts",
    "src/store.ts",
    "src/db.ts",
    "src/types.ts",
    "scripts/*.mjs",
    "test/**/*.test.ts"
  ],
  "project": ["src/**/*.ts", "scripts/**/*.mjs", "test/**/*.ts"],
  "ignore": ["coverage/**", "dist/**", "docs/api/**", "test-results/**"],
  "ignoreExportsUsedInFile": {
    "function": true,
    "type": true
  }
}
