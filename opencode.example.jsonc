{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "debug-recorder-mcp": {
      "type": "local",
      "command": ["npx", "debug-recorder-mcp"],
      "enabled": true,
      "environment": {
        "DEBUG_RECORDER_TRANSPORT": "stdio"
      },
      "timeout": 15000
    }
  },
  "permission": {
    "skill": {
      "debug-session-capture": "allow",
      "incident-replay": "allow",
      "diagnostic-search": "allow"
    }
  }
}
